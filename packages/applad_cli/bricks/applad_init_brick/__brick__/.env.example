# ============================================================
# .env.example
# Keep this file checked into source control.
# Copy this to .env to configure local secrets for Applad.
# ============================================================

# The instance root secret used to encrypt other credentials.
# Generates a new random one if left blank during `applad instance create`.
APPLAD_SECRET=change_this_to_a_random_string_in_production

# Telemetry / Observability secrets
# OTEL_ENDPOINT=https://otlp.eu.example.com
# GRAFANA_URL=https://grafana.example.com
# GRAFANA_API_KEY=your_grafana_token
